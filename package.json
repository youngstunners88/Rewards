{
  "name": "rewards-desktop",
  "version": "1.0.0",
  "description": "Desktop version of the Classroom Reward Tracker",
  "author": "youngstunners88",
  "license": "MIT",
  "main": "electron-main.js",
  "scripts": {
    "start": "electron .",
    "dist": "electron-builder -mwl"
  },
  "devDependencies": {
    "electron": "^31.0.0",
    "electron-builder": "^24.13.3"
  },
  "build": {
    "appId": "com.youngstunners88.rewards",
    "productName": "Rewards - Classroom Point Tracker",
    "directories": {
      "output": "dist"
    },
    "files": [
      "electron-main.js",
      "src/**/*"
    ],
    "win": {
      "target": [
        "nsis"
      ],
      "icon": "build/icon.png"
    },
    "mac": {
      "target": [
        "dmg"
      ],
      "icon": "build/icon.png"
    },
    "linux": {
      "target": [
        "AppImage"
      ],
      "icon": "build/icon.png"
    }
  }
}
